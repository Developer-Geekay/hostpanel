# HostPanel Backend Environment Configuration
# Copy this file to .env and fill in your values:
#   cp .env.example .env && chmod 600 .env

# ── App ───────────────────────────────────────────────────────────────────────
# development → Swagger UI enabled at /docs
# production  → Swagger UI disabled
ENVIRONMENT=development

# ── Security ──────────────────────────────────────────────────────────────────
# Generate a strong key:  openssl rand -hex 32
SECRET_KEY=my-super-secret-key-change-me-in-production

# JWT token lifetime in minutes (1440 = 24 hours)
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ── Admin account ─────────────────────────────────────────────────────────────
# Created automatically on first startup. Protected — cannot be deleted via panel.
DEFAULT_USERNAME=admin
DEFAULT_PASSWORD=changeme

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of origins allowed to call the API
FRONTEND_URLS=http://localhost:4200,http://127.0.0.1:4200,http://yourdomain.com

# ── PowerDNS ──────────────────────────────────────────────────────────────────
# Must match the api-key in pdns.conf
PDNS_API_KEY=hostpanel-dns-api-key

# Nameserver FQDNs — must end with a dot, used when auto-creating DNS zones
PDNS_NS1=ns1.yourdomain.com.
PDNS_NS2=ns2.yourdomain.com.

# ── SSL / Let's Encrypt ───────────────────────────────────────────────────────
CERTBOT_EMAIL=admin@yourdomain.com

# ── Server domain & IP ────────────────────────────────────────────────────────
# The primary domain this panel runs on. Prevents it from being provisioned as a
# hosting domain and blocks /cpanel and /api paths from being overridden by redirects.
SERVER_DOMAIN=yourdomain.com

# Public IPv4 of this server. When set, creating a DNS zone automatically adds
# apex A and www A records pointing here (TTL 3600). Leave blank to skip.
SERVER_IP=

# ── Panel port ────────────────────────────────────────────────────────────────
# Port the panel API + UI listens on. Default 2082.
PANEL_PORT=2082

# ── Panel subdomain ───────────────────────────────────────────────────────────
# Subdomain under SERVER_DOMAIN used to access the panel via HTTPS.
# setup.sh creates: DNS A record, Nginx proxy vhost, and Let's Encrypt cert.
# Result: https://<PANEL_SUBDOMAIN>.<SERVER_DOMAIN>/
# Leave blank to use IP:port only.
PANEL_SUBDOMAIN=cpanel

# ── Misc ──────────────────────────────────────────────────────────────────────
DUMMY_MODE=False
