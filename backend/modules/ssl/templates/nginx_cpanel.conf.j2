# Auto-generated by ssl-cpanel-agent on {{ generated_at }}
# Domain: cpanel.{{ domain }}
# DO NOT EDIT MANUALLY — changes will be overwritten by the agent.

# HTTP: redirect to HTTPS panel port
server {
    listen {{ cpanel_port }};
    server_name cpanel.{{ domain }};

    location ^~ /.well-known/acme-challenge/ {
        root {{ document_root }};
        default_type "text/plain";
        try_files $uri =404;
    }

    location / {
        return 301 https://$host:{{ cpanel_ssl_port }}$request_uri;
    }
}

# HTTPS: SSL termination → proxy to uvicorn on internal backend port
server {
    listen {{ cpanel_ssl_port }} ssl;
    server_name cpanel.{{ domain }};

    ssl_certificate     {{ cert_path }}/fullchain.pem;
    ssl_certificate_key {{ cert_path }}/privkey.pem;

    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_ciphers HIGH:!aNULL:!MD5;
    ssl_session_cache shared:SSL:10m;
    ssl_session_timeout 10m;

    location / {
        proxy_pass http://127.0.0.1:{{ cpanel_backend_port }};
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto https;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_read_timeout 86400;
    }
}
